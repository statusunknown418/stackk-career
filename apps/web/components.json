{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "new-york",
  "rsc": false,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/index.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "registries": {
    "@coss": "https://coss.com/ui/r/{name}.json",
    "@magicui": "https://magicui.design/r/{name}",
    "@ncdai": "https://chanhdai.com/r/{name}.json",
    "@arc": "https://witharc.co/r/{name}.json",
    "@svgl": "https://svgl.app/r/{name}.json",
    "@loading-ui": "https://loading-ui.com/r/{name}.json",
    "@dotmatrix": "https://dotmatrix.zzzzshawn.cloud/r/{name}.json",
    "@tour": "https://onboarding-tour.vercel.app/r/{name}.json",
    "@react-bits": "https://reactbits.dev/r/{name}.json"
  }
