{
  "name": "stackk-career",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "dev:all": "turbo dev trigger:dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @stackk-career/db db:push",
    "db:studio": "turbo -F @stackk-career/db db:studio",
    "db:generate": "turbo -F @stackk-career/db db:generate",
    "db:migrate": "turbo -F @stackk-career/db db:migrate",
    "db:local": "turbo -F @stackk-career/db db:local",
    "db:reset": "pnpm -F @stackk-career/db db:reset",
    "jobs:dev": "turbo -F @stackk-career/jobs trigger:dev",
    "jobs:deploy": "pnpm -F @stackk-career/jobs trigger:deploy",
    "jobs:login": "pnpm -F @stackk-career/jobs trigger:login",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@stackk-career/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@stackk-career/config": "workspace:*",
    "@types/node": "catalog:",
    "husky": "latest",
    "lint-staged": "^17.0.8",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "ultracite": "7.6.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm dlx ultracite fix"
    ]
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
