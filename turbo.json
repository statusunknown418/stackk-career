{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "DATABASE_AUTH_TOKEN",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "CORS_ORIGIN",
    "NODE_ENV",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "AI_GATEWAY_API_KEY",
    "UPLOADTHING_TOKEN",
    "TRIGGER_SECRET_KEY",
    "TRIGGER_PROJECT_ID",
    "AXIOM_API_TOKEN",
    "AXIOM_DATASET",
    "CAL_WEBHOOK_SECRET",
    "VITE_MERCADOPAGO_PUBLIC_KEY",
    "MERCADOPAGO_PUBLIC_KEY",
    "MERCADOPAGO_ACCESS_TOKEN",
    "MERCADOPAGO_WEBHOOK_SECRET",
    "MERCADOPAGO_PRO_MONTHLY_PLAN_ID",
    "MERCADOPAGO_MAX_MONTHLY_PLAN_ID"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:local": {
      "cache": false
    },
    "trigger:dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "trigger:deploy": {
      "cache": false,
      "dependsOn": ["^build"]
    }
  }
}
